{
  "name": "media-pipe-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:express --external:ws --external:node-osc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "node-osc": "^11.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0"
  }
}
